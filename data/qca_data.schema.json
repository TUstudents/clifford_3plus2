{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TUstudents/clifford_3plus2/data/qca_data.schema.json",
  "title": "QCA 3+2 Clifford Split Audit Data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_generators",
    "candidate_complex_structure",
    "allowed_gate_generators",
    "split_projectors"
  ],
  "properties": {
    "structural_origin": {
      "type": "string",
      "enum": [
        "wall_normal_plus_floquet_time",
        "wall_normal_plus_floquet_phase",
        "coin_tau_x_tau_y",
        "arbitrary",
        "unknown"
      ],
      "default": "unknown"
    },
    "candidate_generators": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/candidate_generator"
      }
    },
    "candidate_complex_structure": {
      "$ref": "#/$defs/complex_structure"
    },
    "allowed_gate_generators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_matrix"
      }
    },
    "split_projectors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["P3", "P2"],
      "properties": {
        "P3": {
          "$ref": "#/$defs/matrix"
        },
        "P2": {
          "$ref": "#/$defs/matrix"
        }
      }
    }
  },
  "$defs": {
    "rational": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)(/[1-9][0-9]*)?$"
    },
    "matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/rational"
        }
      }
    },
    "named_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "matrix"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "matrix": {
          "$ref": "#/$defs/matrix"
        }
      }
    },
    "candidate_generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "matrix", "block"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "matrix": {
          "$ref": "#/$defs/matrix"
        },
        "block": {
          "type": "string",
          "enum": ["V3", "V2"]
        }
      }
    },
    "complex_structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "origin", "matrix"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "type": "string",
          "enum": [
            "qca_chirality",
            "floquet_phase",
            "wick_rotation",
            "by_hand",
            "unknown"
          ]
        },
        "matrix": {
          "$ref": "#/$defs/matrix"
        }
      }
    }
  }
}
